{
  "name": "useful-little-times",
  "version": "0.1.0",
  "private": false,
  "description": "Micro-learning for the tiny waiting moments while automated work finishes.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "tsx scripts/build-pages.ts",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx tests/e2e/smoke.ts",
    "worker:dev": "wrangler dev --config worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config worker/wrangler.jsonc",
    "worker:test": "vitest run tests/worker",
    "worker:types": "wrangler types worker/src/worker-configuration.d.ts --config worker/wrangler.jsonc",
    "d1:migrate:local": "wrangler d1 migrations apply useful-little-times --local --config worker/wrangler.jsonc",
    "d1:migrate:remote": "wrangler d1 migrations apply useful-little-times --remote --config worker/wrangler.jsonc",
    "d1:seed:dry-run": "tsx scripts/seed-d1.ts --dry-run",
    "d1:seed:local": "tsx scripts/seed-d1.ts --local",
    "d1:seed:remote": "tsx scripts/seed-d1.ts --remote",
    "content:validate": "tsx scripts/validate-content.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "latest",
    "dotenv": "latest",
    "lucide-react": "latest",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "prettier": "latest",
    "playwright": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
